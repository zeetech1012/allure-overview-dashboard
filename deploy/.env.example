# Copy to .env (gitignored). Secrets live here, never in the frontend bundle.

# --- Huly MCP bridge (do.nbfi.ru) ---
# Same MCP server + token you already use in Claude Code.
HULY_MCP_URL=https://do.nbfi.ru/mcp        # your Huly MCP server endpoint
HULY_TOKEN=                                # bearer token (do NOT commit)
HULY_PROJECT=QA                            # default issue key prefix, e.g. QA-1042
HULY_CREATE_TOOL=create_issue              # name of your MCP "create issue" tool

# --- Allure publish (used by CI, not the dashboard runtime) ---
# ALLURE_BASE is internal to the compose network; CI uses the public URL.
ALLURE_TOKEN=                              # only if allure-docker-service security is on

# --- links shown in the UI (not secrets, just hrefs) ---
GITLAB_BASE=https://gitlab.nbfi.ru
